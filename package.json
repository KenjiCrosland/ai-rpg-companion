{
  "name": "ai-rpg-companion",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest --verbose"
  },
  "dependencies": {
    "@rei/cedar": "^13.3.1",
    "axios": "^1.3.4",
    "detectincognitojs": "^1.3.5",
    "dotenv": "^16.0.3",
    "fs-extra": "^11.1.1",
    "jspdf": "^2.5.1",
    "lodash": "^4.17.21",
    "openai": "^3.2.1",
    "openai-api": "^1.3.1",
    "pinia": "^3.0.4",
    "sass": "^1.60.0",
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.21.5",
    "@babel/preset-react": "^7.18.6",
    "@pinia/testing": "^1.0.3",
    "@rei/cdr-tokens": "^11.0.1",
    "@vitejs/plugin-vue": "^4.2.3",
    "@vue/test-utils": "^2.4.6",
    "@vue/vue3-jest": "^29.2.6",
    "babel-jest": "^29.5.0",
    "happy-dom": "^20.7.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^30.2.0",
    "vite": "^4.3.9"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "customExportConditions": ["node", "node-addons"]
    },
    "setupFilesAfterEnv": ["<rootDir>/jest.setup.js"],
    "transform": {
      "^.+\\.(js|mjs)$": "babel-jest",
      "^.+\\.vue$": "@vue/vue3-jest"
    },
    "moduleFileExtensions": ["js", "json", "vue", "mjs"],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^(\\.{1,2}/.*)\\.mjs$": "$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@rei|@vue)/)"
    ]
  }
}
